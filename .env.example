# ─── Server ────────────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=production

# ─── MySQL ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=institutems

# ─── JWT ───────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# ─── Frontend origin (CORS) ────────────────────────────────────────────────
FRONTEND_URL=*
